DB_HOST=localhost
DB_PORT=5432
DB_NAME=decision_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Optional: provide full URL from Render like postgresql://user:pass@host/db
DB_URL_EXTERNAL=
# Optional: explicit JDBC URL takes highest priority
DB_JDBC_URL=
# Render generally requires SSL
DB_SSL_MODE=require
JWT_SECRET=replace-with-very-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=604800000
